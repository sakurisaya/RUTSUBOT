# =====================================================
# RUTSUBOT 環境設定ファイル (サンプル)
#
# このファイルをコピーして "env.ps1" にリネームし、
# 自分のPC環境に合わせてパスを書き換えてください。
#
# env.ps1 は .gitignore に含まれているため、
# Git にはコミットされません。
# =====================================================

# Tomcat のインストール先ディレクトリ
# 例: "C:\apache-tomcat-10.1.54"
# 例: "C:\tools\tomcat"
$TOMCAT_HOME = "C:\apache-tomcat-10.1.54"

# Java のインストール先 (通常は自動検出されるので空欄でOK)
# 空欄の場合は環境変数 JAVA_HOME または
# Eclipse Temurin 17 の自動検出を使用します
# 例: "C:\Program Files\Eclipse Adoptium\jdk-17.0.12.7-hotspot"
$JAVA_HOME_OVERRIDE = ""
